{
  "agent": { "run_as_user": "root", "logfile": "/opt/aws/amazon-cloudwatch-agent/logs/amazon-cloudwatch-agent.log" },
  "logs": {
    "logs_collected": { "files": { "collect_list": [{ "file_path": "/var/log/nexabank-transaction-service.log", "log_group_name": "/nexabank/production/transaction-service", "log_stream_name": "{instance_id}", "timezone": "UTC" }] } },
    "force_flush_interval": 15
  },
  "metrics": {
    "namespace": "NexaBank/TransactionService",
    "append_dimensions": { "InstanceId": "${aws:InstanceId}" },
    "metrics_collected": {
      "cpu": { "measurement": ["cpu_usage_active","cpu_usage_idle"], "metrics_collection_interval": 60 },
      "mem": { "measurement": ["mem_used_percent","mem_available_percent"], "metrics_collection_interval": 60 },
      "disk": { "measurement": ["disk_used_percent"], "resources": ["/"], "metrics_collection_interval": 300 }
    }
  }
}